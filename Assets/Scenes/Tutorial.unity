  m_Script: {fileID: 11500000, guid: 5db814ba393e51e4a5f1d5ca2f741c2c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Bash
  description: Press <Bash> to knock lighter enemies backwards. If an enemy collides
    with a wall or terrain, they become stunned for a short time. You can also Bash
    lighter enemies off ledges for an instant kill during normal gameplay. Panquakes
    are too heavy to be knocked back.
  promptActionName: Bash
  spawner: {fileID: 76632288}
  completeDelay: 2
  bashObjectiveText: Bash the Training Dummy into the wall
  stunObjectiveText: Stun the Training Dummy
